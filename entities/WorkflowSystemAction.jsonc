{
  "name": "WorkflowSystemAction",
  "type": "object",
  "properties": {
    "workflow_transition_id": {
      "type": "string",
      "description": "Reference to WorkflowTransition"
    },
    "action_type": {
      "type": "string",
      "enum": [
        "change_status",
        "update_field",
        "send_notification",
        "create_related_record",
        "assign_role",
        "set_flag"
      ],
      "description": "Type of system action"
    },
    "action_parameters": {
      "type": "string",
      "description": "JSON parameters for the action"
    },
    "sort_order": {
      "type": "number",
      "default": 10
    }
  },
  "required": [
    "workflow_transition_id",
    "action_type"
  ]
}