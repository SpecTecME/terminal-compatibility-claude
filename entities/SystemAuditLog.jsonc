{
  "name": "SystemAuditLog",
  "type": "object",
  "properties": {
    "module_name": {
      "type": "string",
      "description": "Module where change occurred"
    },
    "entity_name": {
      "type": "string",
      "description": "Entity type changed"
    },
    "record_id": {
      "type": "string",
      "description": "ID of the changed record"
    },
    "action_type": {
      "type": "string",
      "enum": [
        "create",
        "update",
        "delete",
        "activate",
        "deactivate"
      ],
      "description": "Type of action"
    },
    "old_value_json": {
      "type": "string",
      "description": "Previous value as JSON string"
    },
    "new_value_json": {
      "type": "string",
      "description": "New value as JSON string"
    },
    "changed_by": {
      "type": "string",
      "description": "Email of user who made the change"
    },
    "changed_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of change"
    }
  },
  "required": [
    "module_name",
    "entity_name",
    "action_type",
    "changed_by",
    "changed_at"
  ]
}