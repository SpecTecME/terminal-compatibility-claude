{
  "name": "TerminalProcedure",
  "type": "object",
  "properties": {
    "publicId": {
      "type": "string",
      "description": "UUID for migration portability"
    },
    "tenantId": {
      "type": "string",
      "description": "Tenant identifier"
    },
    "terminal_id": {
      "type": "string",
      "description": "Base44 reference to Terminal"
    },
    "terminalPublicId": {
      "type": "string",
      "description": "Terminal publicId for migration"
    },
    "title": {
      "type": "string",
      "description": "Procedure title"
    },
    "content": {
      "type": "string",
      "description": "Rich text/HTML procedure content"
    },
    "version": {
      "type": "string",
      "description": "Procedure version"
    },
    "last_updated": {
      "type": "string",
      "format": "date",
      "description": "Last update date"
    }
  },
  "required": [
    "publicId",
    "tenantId",
    "terminal_id",
    "title"
  ]
}