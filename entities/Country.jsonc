{
  "name": "Country",
  "type": "object",
  "properties": {
    "publicId": {
      "type": "string",
      "description": "UUID for migration portability"
    },
    "tenantId": {
      "type": "string",
      "description": "Tenant identifier - for master data, use 'global' or specific tenant"
    },
    "iso2": {
      "type": "string",
      "description": "ISO 3166-1 alpha-2 code (e.g., AE, US, GB) - unique"
    },
    "iso3": {
      "type": "string",
      "description": "ISO 3166-1 alpha-3 code (e.g., ARE, USA, GBR) - optional"
    },
    "nameEn": {
      "type": "string",
      "description": "English name of the country"
    },
    "validFrom": {
      "type": "string",
      "format": "date",
      "description": "Date from which the country is valid"
    },
    "validTo": {
      "type": "string",
      "format": "date",
      "description": "Date until which the country is valid - null means currently active"
    },
    "isActive": {
      "type": "boolean",
      "default": true,
      "description": "Whether the country is active - computed from validFrom/validTo"
    }
  },
  "required": [
    "publicId",
    "tenantId",
    "iso2",
    "nameEn"
  ]
}