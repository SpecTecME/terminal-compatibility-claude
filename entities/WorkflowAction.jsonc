{
  "name": "WorkflowAction",
  "type": "object",
  "properties": {
    "workflow_definition_id": {
      "type": "string",
      "description": "Reference to WorkflowDefinition"
    },
    "action_name": {
      "type": "string",
      "description": "Action display name"
    },
    "action_code": {
      "type": "string",
      "description": "Action code (unique within workflow)"
    },
    "description": {
      "type": "string",
      "description": "Description of what this action does"
    },
    "sort_order": {
      "type": "number",
      "default": 10
    }
  },
  "required": [
    "workflow_definition_id",
    "action_name",
    "action_code"
  ]
}