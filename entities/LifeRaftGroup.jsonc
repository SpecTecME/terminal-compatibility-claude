{
  "name": "LifeRaftGroup",
  "type": "object",
  "properties": {
    "publicId": {
      "type": "string",
      "description": "UUID for migration portability"
    },
    "tenantId": {
      "type": "string",
      "description": "Tenant identifier"
    },
    "vesselId": {
      "type": "string",
      "description": "Base44 reference to Vessel"
    },
    "vesselPublicId": {
      "type": "string",
      "description": "Vessel publicId for migration"
    },
    "zoneId": {
      "type": "string",
      "description": "Base44 reference to VesselZone"
    },
    "zonePublicId": {
      "type": "string",
      "description": "Zone publicId for migration"
    },
    "groupCode": {
      "type": "string",
      "description": "Unique group code per vessel (e.g., LR-FWD-P)"
    },
    "side": {
      "type": "string",
      "enum": [
        "PORT",
        "STARBOARD",
        "CENTER",
        "NA"
      ],
      "description": "Side of vessel"
    },
    "deck": {
      "type": "string",
      "description": "Deck identifier"
    },
    "raftCount": {
      "type": "number",
      "description": "Number of rafts (min 0)"
    },
    "capacityPerRaft": {
      "type": "number",
      "description": "Capacity per raft (min 0)"
    },
    "totalCapacity": {
      "type": "number",
      "description": "Total capacity (raftCount * capacityPerRaft)"
    },
    "status": {
      "type": "string",
      "enum": [
        "ACTIVE",
        "OUT_OF_SERVICE"
      ],
      "default": "ACTIVE",
      "description": "Life raft group status"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes"
    }
  },
  "required": [
    "publicId",
    "tenantId",
    "vesselId",
    "vesselPublicId",
    "groupCode"
  ]
}