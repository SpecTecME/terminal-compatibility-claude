{
  "name": "Berth",
  "type": "object",
  "properties": {
    "publicId": {
      "type": "string",
      "description": "UUID for migration portability"
    },
    "tenantId": {
      "type": "string",
      "description": "Tenant identifier"
    },
    "terminalPublicId": {
      "type": "string",
      "description": "Terminal publicId for migration"
    },
    "berthCode": {
      "type": "string",
      "description": "Berth code (e.g., LNG1)"
    },
    "berthName": {
      "type": "string",
      "description": "Berth name (e.g., Ras Laffan LNG Berth 1)"
    },
    "berth_number": {
      "type": "string",
      "description": "Berth identifier (e.g., Berth 1, Berth A)"
    },
    "berthType": {
      "type": "string",
      "enum": [
        "Jetty",
        "Quay",
        "SPM",
        "Dolphin",
        "Other"
      ],
      "description": "Type of berth"
    },
    "productTypeRefIds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "References to ProductTypeRef (Products handled by this berth)"
    },
    "max_loa": {
      "type": "number",
      "description": "Maximum Length Overall in meters"
    },
    "max_beam": {
      "type": "number",
      "description": "Maximum beam in meters"
    },
    "max_draft": {
      "type": "number",
      "description": "Maximum draft in meters"
    },
    "min_cargo_capacity": {
      "type": "number",
      "description": "Minimum cargo capacity in cubic meters"
    },
    "max_cargo_capacity": {
      "type": "number",
      "description": "Maximum cargo capacity in cubic meters"
    },
    "qmaxCapable": {
      "type": "boolean",
      "description": "Whether berth can accommodate Q-Max vessels"
    },
    "qflexCapable": {
      "type": "boolean",
      "description": "Whether berth can accommodate Q-Flex vessels"
    },
    "maxCargoCapacityM3": {
      "type": "number",
      "description": "Maximum cargo capacity in cubic meters"
    },
    "maxLOAM": {
      "type": "number",
      "description": "Maximum Length Overall in meters"
    },
    "maxBeamM": {
      "type": "number",
      "description": "Maximum beam in meters"
    },
    "maxArrivalDraftM": {
      "type": "number",
      "description": "Maximum arrival draft in meters"
    },
    "maxArrivalDisplacementT": {
      "type": "number",
      "description": "Maximum arrival displacement in tonnes"
    },
    "manifoldLimitsNotes": {
      "type": "string",
      "description": "Manifold limits and notes"
    },
    "manifold_height_min": {
      "type": "number",
      "description": "Minimum manifold height in meters"
    },
    "manifold_height_max": {
      "type": "number",
      "description": "Maximum manifold height in meters"
    },
    "loadingArmsLngCount": {
      "type": "number",
      "description": "Number of LNG loading arms"
    },
    "vapourReturnAvailable": {
      "type": "boolean",
      "description": "Whether vapour return is available"
    },
    "typicalLoadingRateNotes": {
      "type": "string",
      "description": "Typical loading rate notes"
    },
    "loading_arms": {
      "type": "number",
      "description": "Number of loading arms"
    },
    "fenders_type": {
      "type": "string",
      "description": "Type of fenders installed"
    },
    "bollards_capacity": {
      "type": "number",
      "description": "Bollard capacity in tonnes"
    },
    "operator": {
      "type": "string",
      "description": "Berth operator"
    },
    "dataSource": {
      "type": "string",
      "description": "Data source reference"
    },
    "lastVerifiedDate": {
      "type": "string",
      "format": "date",
      "description": "Date when data was last verified"
    },
    "description": {
      "type": "string",
      "description": "Berth description and specifications"
    },
    "status": {
      "type": "string",
      "enum": [
        "Active",
        "Maintenance",
        "Inactive",
        "Operational",
        "Planned",
        "Under Construction"
      ],
      "default": "Active"
    },
    "notes": {
      "type": "string",
      "description": "Additional specifications or notes"
    },
    "isArchived": {
      "type": "boolean",
      "default": false,
      "description": "Whether the berth is archived (soft delete)"
    },
    "archivedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Date and time when archived"
    },
    "archivedReason": {
      "type": "string",
      "description": "Reason for archiving"
    }
  },
  "required": [
    "publicId",
    "tenantId",
    "terminalPublicId",
    "berth_number"
  ]
}