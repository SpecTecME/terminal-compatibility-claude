{
  "name": "WorkflowTransition",
  "type": "object",
  "properties": {
    "workflow_definition_id": {
      "type": "string",
      "description": "Reference to WorkflowDefinition"
    },
    "from_status_id": {
      "type": "string",
      "description": "Reference to WorkflowStatus (from) \u2014 omitted for initial transitions"
    },
    "to_status_id": {
      "type": "string",
      "description": "Reference to WorkflowStatus (to)"
    },
    "workflow_action_id": {
      "type": "string",
      "description": "Reference to WorkflowAction that triggers this transition"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "workflow_definition_id",
    "to_status_id",
    "workflow_action_id"
  ]
}