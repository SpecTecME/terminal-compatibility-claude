{
  "name": "TerminalRegistrationAttachment",
  "type": "object",
  "properties": {
    "publicId": {
      "type": "string",
      "description": "UUID for migration portability"
    },
    "tenantId": {
      "type": "string",
      "description": "Tenant identifier"
    },
    "applicationId": {
      "type": "string",
      "description": "Base44 reference to TerminalRegistrationApplication"
    },
    "applicationPublicId": {
      "type": "string",
      "description": "Application publicId for migration"
    },
    "attachmentType": {
      "type": "string",
      "enum": [
        "VESSEL_DOCUMENT_LINK",
        "COMPLETED_FORM",
        "SUPPORTING_FILE"
      ],
      "description": "Type of attachment"
    },
    "fileName": {
      "type": "string",
      "description": "File name"
    },
    "fileUrl": {
      "type": "string",
      "description": "File URL"
    },
    "vesselDocumentId": {
      "type": "string",
      "description": "Base44 reference to Document if linked"
    },
    "vesselDocumentPublicId": {
      "type": "string",
      "description": "Vessel document publicId"
    },
    "documentTypeId": {
      "type": "string",
      "description": "Base44 reference to DocumentType"
    },
    "documentTypePublicId": {
      "type": "string",
      "description": "DocumentType publicId"
    },
    "status": {
      "type": "string",
      "enum": [
        "ACTIVE",
        "ARCHIVED"
      ],
      "default": "ACTIVE",
      "description": "Attachment status"
    },
    "uploadedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Upload timestamp"
    },
    "uploadedByUserId": {
      "type": "string",
      "description": "User who uploaded"
    },
    "notes": {
      "type": "string",
      "description": "Short notes"
    }
  },
  "required": [
    "publicId",
    "tenantId",
    "applicationId",
    "applicationPublicId",
    "attachmentType",
    "fileName",
    "fileUrl"
  ]
}