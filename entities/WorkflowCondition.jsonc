{
  "name": "WorkflowCondition",
  "type": "object",
  "properties": {
    "workflow_transition_id": {
      "type": "string",
      "description": "Reference to WorkflowTransition"
    },
    "condition_type": {
      "type": "string",
      "enum": [
        "field_value",
        "role_check",
        "boolean_flag",
        "record_comparison"
      ],
      "description": "Type of condition"
    },
    "condition_expression": {
      "type": "string",
      "description": "Condition expression or value"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description"
    },
    "sort_order": {
      "type": "number",
      "default": 10
    }
  },
  "required": [
    "workflow_transition_id",
    "condition_type"
  ]
}