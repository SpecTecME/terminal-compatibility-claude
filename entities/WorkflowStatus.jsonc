{
  "name": "WorkflowStatus",
  "type": "object",
  "properties": {
    "workflow_definition_id": {
      "type": "string",
      "description": "Reference to WorkflowDefinition"
    },
    "status_name": {
      "type": "string",
      "description": "Status display name"
    },
    "status_code": {
      "type": "string",
      "description": "Status code (unique within workflow)"
    },
    "color_code": {
      "type": "string",
      "description": "Hex color code e.g. #3B82F6"
    },
    "is_initial": {
      "type": "boolean",
      "default": false,
      "description": "Is this the starting status?"
    },
    "is_final": {
      "type": "boolean",
      "default": false,
      "description": "Is this a terminal status?"
    },
    "sort_order": {
      "type": "number",
      "default": 10
    }
  },
  "required": [
    "workflow_definition_id",
    "status_name",
    "status_code"
  ]
}